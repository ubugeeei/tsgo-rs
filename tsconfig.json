{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@tsgo-rs/tsgo-rs-node": ["./npm/tsgo_rs_node/ts/index.ts"],
      "typescript-oxlint": ["./npm/typescript_oxlint/ts/index.ts"],
      "typescript-oxlint/ast-utils": ["./npm/typescript_oxlint/ts/ast_utils.ts"],
      "typescript-oxlint/eslint-utils": ["./npm/typescript_oxlint/ts/eslint_utils.ts"],
      "typescript-oxlint/json-schema": ["./npm/typescript_oxlint/ts/json_schema.ts"],
      "typescript-oxlint/rule-tester": ["./npm/typescript_oxlint/ts/rule_tester.ts"],
      "typescript-oxlint/rules": ["./npm/typescript_oxlint/ts/rules/index.ts"],
      "typescript-oxlint/ts-eslint": ["./npm/typescript_oxlint/ts/ts_eslint.ts"],
      "typescript-oxlint/ts-estree": ["./npm/typescript_oxlint/ts/ts_estree.ts"]
    },
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "bench/**/*.ts",
    "npm/typescript_oxlint/ts/**/*.ts",
    "npm/typescript_oxlint/tsconfig.json",
    "npm/tsgo_rs_node/index.d.ts",
    "npm/tsgo_rs_node/ts/**/*.ts",
    "vite.config.ts"
  ]
}
