{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "paths": {
      "@tsgo-rs/node": ["./npm/tsgo_rs_node/ts/index.ts"],
      "oxlint-plugin-typescript-go": ["./npm/typescript_oxlint/ts/index.ts"],
      "oxlint-plugin-typescript-go/ast-utils": ["./npm/typescript_oxlint/ts/ast_utils.ts"],
      "oxlint-plugin-typescript-go/eslint-utils": ["./npm/typescript_oxlint/ts/eslint_utils.ts"],
      "oxlint-plugin-typescript-go/json-schema": ["./npm/typescript_oxlint/ts/json_schema.ts"],
      "oxlint-plugin-typescript-go/rule-tester": ["./npm/typescript_oxlint/ts/rule_tester.ts"],
      "oxlint-plugin-typescript-go/rules": ["./npm/typescript_oxlint/ts/rules/index.ts"],
      "oxlint-plugin-typescript-go/ts-eslint": ["./npm/typescript_oxlint/ts/ts_eslint.ts"],
      "oxlint-plugin-typescript-go/ts-estree": ["./npm/typescript_oxlint/ts/ts_estree.ts"]
    },
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "bench/**/*.ts",
    "examples/**/*.ts",
    "npm/typescript_oxlint/ts/**/*.ts",
    "npm/typescript_oxlint/tsconfig.json",
    "npm/tsgo_rs_node/index.d.ts",
    "npm/tsgo_rs_node/ts/**/*.ts",
    "scripts/**/*.ts",
    "vite.config.ts"
  ]
}
