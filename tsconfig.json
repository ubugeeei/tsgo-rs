{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "rewriteRelativeImportExtensions": true,
    "paths": {
      "@corsa-bind/napi": ["./src/bindings/nodejs/corsa_node/ts/index.ts"],
      "corsa-oxlint": ["./src/bindings/nodejs/typescript_oxlint/ts/index.ts"],
      "corsa-oxlint/ast-utils": ["./src/bindings/nodejs/typescript_oxlint/ts/ast_utils.ts"],
      "corsa-oxlint/compat": ["./src/bindings/nodejs/typescript_oxlint/ts/oxlint_compat.ts"],
      "corsa-oxlint/json-schema": ["./src/bindings/nodejs/typescript_oxlint/ts/json_schema.ts"],
      "corsa-oxlint/oxlint-utils": ["./src/bindings/nodejs/typescript_oxlint/ts/oxlint_utils.ts"],
      "corsa-oxlint/rule-tester": ["./src/bindings/nodejs/typescript_oxlint/ts/rule_tester.ts"],
      "corsa-oxlint/rules": ["./src/bindings/nodejs/typescript_oxlint/ts/rules/index.ts"],
      "corsa-oxlint/ts-estree": ["./src/bindings/nodejs/typescript_oxlint/ts/ts_estree.ts"]
    },
    "strict": true,
    "declaration": true,
    "sourceMap": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "types": ["node"]
  },
  "include": [
    "bench/**/*.ts",
    "examples/**/*.ts",
    "src/bindings/nodejs/typescript_oxlint/ts/**/*.ts",
    "src/bindings/nodejs/typescript_oxlint/tsconfig.json",
    "src/bindings/nodejs/corsa_node/index.d.ts",
    "src/bindings/nodejs/corsa_node/ts/**/*.ts",
    "scripts/**/*.ts",
    "vite.config.ts"
  ]
}
