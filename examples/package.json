{
  "name": "tsgo-rs-examples",
  "private": true,
  "type": "module",
  "scripts": {
    "smoke": "node --strip-types ./smoke.ts",
    "minimal-start": "node --strip-types ./node/minimal_start.ts",
    "mock-client": "node --strip-types ./node/mock_client.ts",
    "raw-calls": "node --strip-types ./node/raw_calls.ts",
    "unsafe-type-flow": "node --strip-types ./node/unsafe_type_flow.ts",
    "virtual-document": "node --strip-types ./node/virtual_document.ts",
    "distributed-orchestrator": "node --strip-types ./node/distributed_orchestrator.ts",
    "real-snapshot": "node --strip-types ./node/real_snapshot.ts",
    "rule-tester": "node --strip-types ./typescript_oxlint/rule_tester.ts",
    "native-rule-tester": "node --strip-types ./typescript_oxlint/native_rule_tester.ts",
    "real": "pnpm run real-snapshot && pnpm run rule-tester && pnpm run native-rule-tester"
  },
  "dependencies": {
    "@tsgo-rs/node": "workspace:*",
    "oxlint-plugin-typescript-go": "workspace:*"
  },
  "engines": {
    "node": ">=24"
  }
