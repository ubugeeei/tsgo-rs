{
  "name": "typescript-oxlint",
  "version": "0.1.0",
  "description": "typescript-eslint-style Oxlint helpers powered by tsgo-rs and typescript-go",
  "homepage": "https://github.com/ubugeeei/tsgo-rs/tree/main/npm/typescript_oxlint",
  "bugs": {
    "url": "https://github.com/ubugeeei/tsgo-rs/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ubugeeei/tsgo-rs.git",
    "directory": "npm/typescript_oxlint"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./ast-utils": {
      "types": "./dist/ast_utils.d.ts",
      "import": "./dist/ast_utils.js"
    },
    "./eslint-utils": {
      "types": "./dist/eslint_utils.d.ts",
      "import": "./dist/eslint_utils.js"
    },
    "./json-schema": {
      "types": "./dist/json_schema.d.ts",
      "import": "./dist/json_schema.js"
    },
    "./rule-tester": {
      "types": "./dist/rule_tester.d.ts",
      "import": "./dist/rule_tester.js"
    },
    "./rules": {
      "types": "./dist/rules/index.d.ts",
      "import": "./dist/rules/index.js"
    },
    "./ts-eslint": {
      "types": "./dist/ts_eslint.d.ts",
      "import": "./dist/ts_eslint.js"
    },
    "./ts-estree": {
      "types": "./dist/ts_estree.d.ts",
      "import": "./dist/ts_estree.js"
    },
    "./package.json": "./package.json"
  },
  "dependencies": {
    "@oxlint/plugins": "1.57.0",
    "@tsgo-rs/tsgo-rs-node": "workspace:*",
    "oxlint": "1.57.0"
  },
  "engines": {
    "node": ">=22"
  }
}
