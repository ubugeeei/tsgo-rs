{
  "name": "@corsa-bind/node",
  "version": "0.1.0",
  "description": "Native Node.js bindings for corsa-bind and typescript-go stdio workflows",
  "homepage": "https://github.com/ubugeeei/corsa-bind/tree/main/npm/corsa_bind_node",
  "bugs": {
    "url": "https://github.com/ubugeeei/corsa-bind/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ubugeeei/corsa-bind.git",
    "directory": "npm/corsa_bind_node"
  },
  "files": [
    "dist",
    "README.md",
    "index.d.ts",
    "index.js"
  ],
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "default": "./dist/index.mjs",
      "import": "./dist/index.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "napi": {
    "name": "corsa_bind_node",
    "triples": {
      "additional": [
        "aarch64-apple-darwin"
      ]
    }
  },
  "engines": {
    "node": ">=22"
  }
}
